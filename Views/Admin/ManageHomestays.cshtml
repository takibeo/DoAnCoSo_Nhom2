@model List<DoAnCoSo_Nhom2.Models.Homestay>

<style>
    html, body {
        height: 100%;
        margin: 0;
    }
    body {
        background: linear-gradient(135deg, #F5EDE1, #feb47b);
        padding-top: 50px;
    }

    h2 {
        font-size: 28px;
        font-weight: bold;
        color: #4E1F00;
        text-align: center;
        text-transform: uppercase;
    }

    .table th {
        background-color: #4E1F00;
        color: #FFF3C7;
        vertical-align: middle;
    }

    .table td {
        background-color: #FFE699 !important;
        color: #4E1F00;
        vertical-align: middle;
    }

    .badge {
        font-size: 0.9em;
        padding: 5px 10px;
        border-radius: 5px;
    }

    .alert-info {
        font-size: 18px;
        font-weight: bold;
        background-color: #FFF3C7;
        color: #4E1F00;
        border: none;
        border-radius: 10px;
    }

    .btn-secondary {
        background-color: #FFF3C7;
        color: #4E1F00;
        border: none;
        font-weight: bold;
        border-radius: 10px;
    }

    .btn-secondary:hover {
        background-color: #F2E2B1;
    }

    #homestayTable_wrapper {
        color: #4E1F00;
        font-size: 16px;
    }

    .dataTables_length label,
    .dataTables_filter label,
    .dataTables_info,
    .dataTables_paginate {
        color: #4E1F00 !important;
        font-size: 16px;
    }

    .dataTables_length select,
    .dataTables_filter input,
    .dataTables_paginate a {
        font-size: 16px !important;
        color: #4E1F00 !important;
        background-color: white !important;
        border: 1px solid #ccc !important;
        border-radius: 6px;
        padding: 4px 8px;
        margin: 2px;
    }

    .dataTables_paginate .paginate_button {
        padding: 6px 12px;
        margin: 2px;
    }

    .dataTables_paginate .paginate_button:hover {
        background-color: #f1f1f1 !important;
        color: #4E1F00 !important;
        border: 1px solid #4E1F00 !important;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button.current {
        background-color: white !important;
        color: #FFF3C7 !important;
        border: 1px solid #4E1F00 !important;
    }

    .text-center {
        text-align: center;
    }

    .text-end {
        text-align: right;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    .table-responsive {
        margin-top: 30px;
    }
</style>

<h2>Quản lý Homestay</h2>

<div class="container">
    <div class="table-responsive">
        <table id="homestayTable" class="table table-hover table-bordered text-center">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tên</th>
                    <th>Địa chỉ</th>
                    <th>Thành phố</th>
                    <th>Giá mỗi đêm</th>
                    <th>Trạng thái</th>
                    <th>Staff</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var homestay in Model)
                {
                    <tr>
                        <td>@homestay.Id</td>
                        <td>@homestay.Name</td>
                        <td>@homestay.Address</td>
                        <td>@homestay.City</td>
                        <td>@homestay.PricePerNight.ToString("N0") VND</td>
                        <td>
                            <span class="badge @(homestay.IsApproved ? "bg-success" : "bg-warning")">
                                @(homestay.IsApproved ? "Đã phê duyệt" : "Chưa phê duyệt")
                            </span>
                        </td>
                        <td>@homestay.Staff?.FullName</td>
                        <td>
                            <div class="d-flex gap-2 justify-content-center">
                                @if (!homestay.IsApproved)
                                {
                                    <form asp-controller="Admin" asp-action="ApproveHomestay" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@homestay.Id" />
                                        <button type="submit" class="btn btn-success btn-sm">Phê duyệt</button>
                                    </form>
                                }
                                <a asp-action="EditHomestay" asp-route-id="@homestay.Id" class="btn btn-primary btn-sm">Sửa</a>
                                <form asp-action="DeleteHomestay" method="post" onsubmit="return confirm('Bạn chắc chắn muốn xóa?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@homestay.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="text-end mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#homestayTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json'
                },
                pageLength: 10 
            });
        });
    </script>
}
