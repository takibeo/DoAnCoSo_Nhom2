
<style>
    html, body {
        height: 100%;
        margin: 0;
    }

    body {
        background: linear-gradient(135deg, #F5EDE1, #feb47b);
        padding-top: 50px;
    }

    h2, h3 {
        font-weight: bold;
        color: orangered !important;
        text-align: center;
        text-transform: uppercase;
    }

    .table th {
        background-color: #4E1F00;
        color: #FFF3C7;
        vertical-align: middle;
    }

    .table td {
        background-color: #FFE699 !important;
        color: #4E1F00;
        vertical-align: middle;
    }

    .badge {
        font-size: 0.9em;
        padding: 5px 10px;
        border-radius: 5px;
    }

    .btn-secondary {
        background-color: #FFF3C7;
        color: #4E1F00;
        border: none;
        font-weight: bold;
        border-radius: 10px;
    }

        .btn-secondary:hover {
            background-color: #F2E2B1;
        }

    .btn-primary {
        background-color: deepskyblue !important;
        border: none;
        font-weight: bold;
    }

    .form-label {
        font-weight: bold;
        color: #4E1F00;
    }

    .form-control {
        border-radius: 8px;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    .table-responsive {
        margin-top: 30px;
    }

    .text-end {
        text-align: right;
    }

</style>

<div class="container">
    <h2 class="mb-4">Thống kê đơn đặt phòng</h2>

    <form method="get" asp-action="ThongKeBooking" class="mb-4">
        <div class="row">
            <div class="col-md-4">
                <label for="homestayName" class="form-label">Nhập tên Homestay:</label>
                <input type="text" name="homestayName" id="homestayName" list="homestayList" class="form-control" />
                <datalist id="homestayList">
                    @foreach (var homestay in ViewBag.Homestays)
                    {
                        <option value="@homestay.Name"></option>
                    }
                </datalist>
            </div>
            <div class="col-md-3">
                <label for="fromDate" class="form-label">Từ ngày:</label>
                <input type="date" name="fromDate" id="fromDate" class="form-control" />
            </div>
            <div class="col-md-3">
                <label for="toDate" class="form-label">Đến ngày:</label>
                <input type="date" name="toDate" id="toDate" class="form-control" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Lọc</button>
            </div>
        </div>
    </form>

    <h3 class="mt-4">Thống kê tổng quan</h3>
    <div class="table-responsive">
        <table class="table table-striped table-bordered text-center">
            <thead>
                <tr>
                    <th>Trạng thái</th>
                    <th>Số lượng</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var stat in Model.StatusStatistics)
                {
                    <tr>
                        <td>@stat.Status</td>
                        <td>@stat.Count</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <h3 class="mt-4">Thống kê doanh thu</h3>
    <div class="table-responsive">
        <table class="table table-striped table-bordered text-center">
            <thead>
                <tr>
                    <th>Tháng</th>
                    <th>Doanh thu</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var revenue in Model.RevenueStatistics)
                {
                    <tr>
                        <td>@revenue.Month</td>
                        <td>@revenue.TotalRevenue.ToString("N0") VND</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <h3 class="mt-4">Chi tiết đơn đặt phòng</h3>
    <div class="table-responsive">
        <table class="table table-striped table-bordered text-center">
            <thead>
                <tr>
                    <th>Khách hàng</th>
                    <th>Homestay</th>
                    <th>Ngày nhận</th>
                    <th>Ngày trả</th>
                    <th>Số khách</th>
                    <th>Giá</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model.Bookings)
                {
                    <tr>
                        <td>@booking.User.FullName</td>
                        <td>@booking.Homestay.Name</td>
                        <td>@booking.CheckInDate.ToString("dd/MM/yyyy")</td>
                        <td>@booking.CheckOutDate.ToString("dd/MM/yyyy")</td>
                        <td>@booking.NumberOfGuests</td>
                        <td>@booking.TotalPrice.ToString("N0") VND</td>
                        <td>
                            @{
                                var badgeClass = booking.Status switch
                                {
                                    "Pending" => "bg-warning",
                                    "Approved" => "bg-success",
                                    _ => "bg-danger"
                                };
                            }
                            <span class="badge @badgeClass">@booking.Status</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="text-end mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>
