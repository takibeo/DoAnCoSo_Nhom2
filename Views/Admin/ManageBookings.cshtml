@model List<Booking>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&display=swap" rel="stylesheet">

<style>
    html, body {
        height: 100%;
        margin: 0;
    }

    body {
        background: linear-gradient(135deg, #F5EDE1, #feb47b);
        padding-top: 50px;
        color: black;
    }

    .booking-container {
        background-color: #A27B5C;
        color: #FFF3C7;
        border-radius: 20px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        padding: 30px;
        max-width: 1000px;
        margin: 0 auto;
    }

    h2 {
        font-size: 28px;
        font-weight: bold;
        color: #FFF3C7;
        text-align: center;
        margin-bottom: 30px;
        text-transform: uppercase;
    }

    .table th {
        background-color: #4E1F00;
        color: #FFF3C7;
        vertical-align: middle;
    }

    .table td {
        background-color: #FFE699 !important;
        color: #4E1F00;
        vertical-align: middle;
    }

    .badge {
        font-size: 0.9em;
        padding: 5px 10px;
        border-radius: 10px;
    }

    .alert-info {
        font-size: 18px;
        font-weight: bold;
        background-color: #FFF3C7;
        color: #4E1F00;
        border: none;
        border-radius: 10px;
    }

    .btn-secondary {
        background-color: #FFF3C7;
        color: #4E1F00;
        border: none;
        font-weight: bold;
        border-radius: 10px;
    }

        .btn-secondary:hover {
            background-color: #F2E2B1;
        }

    #bookingTable_wrapper {
        color: #4E1F00;
        font-size: 16px;
    }

    .dataTables_length label,
    .dataTables_filter label,
    .dataTables_info,
    .dataTables_paginate {
        color: #4E1F00 !important;
        font-size: 16px;
    }

        .dataTables_length select,
        .dataTables_filter input,
        .dataTables_paginate a {
            font-size: 16px !important;
            color: #4E1F00 !important;
            background-color: white !important;
            border: 1px solid #ccc !important;
            border-radius: 6px;
            padding: 4px 8px;
            margin: 2px;
        }

        .dataTables_paginate .paginate_button {
            padding: 6px 12px;
            margin: 2px;
        }

            .dataTables_paginate .paginate_button:hover {
                background-color: #f1f1f1 !important;
                color: #4E1F00 !important;
                border: 1px solid #4E1F00 !important;
            }

    .dataTables_wrapper .dataTables_paginate .paginate_button.current {
        background-color: white !important;
        color: #FFF3C7 !important;
        border: 1px solid #4E1F00 !important;
    }
</style>

<div class="booking-container">
    <h2>Quản lý đơn đặt phòng</h2>

    <div class="table-responsive">
        <table id="bookingTable" class="table table-hover table-bordered text-center">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Người đặt</th>
                    <th>Homestay</th>
                    <th>Ngày đến</th>
                    <th>Ngày đi</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model)
                {
                    <tr>
                        <td>@booking.Id</td>
                        <td>@booking.User.FullName</td>
                        <td>@booking.Homestay.Name</td>
                        <td>@booking.CheckInDate.ToShortDateString()</td>
                        <td>@booking.CheckOutDate.ToShortDateString()</td>
                        <td>
                            <span class="badge @(booking.Status == "Pending" ? "bg-warning" :
                                                  booking.Status == "Approved" ? "bg-success" : "bg-danger")">
                                @booking.Status
                            </span>
                        </td>
                        <td>
                            @if (booking.Status == "Pending")
                            {
                                <form asp-action="ApproveBooking" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@booking.Id" />
                                    <button type="submit" class="btn btn-success btn-sm">Duyệt</button>
                                </form>
                                <form asp-action="CancelBooking" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@booking.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Hủy</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="text-end mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#bookingTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json'
                },
                pageLength: 10
            });
        });
    </script>
}
