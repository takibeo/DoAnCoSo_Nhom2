@model List<DoAnCoSo_Nhom2.Models.Booking>
@{
    ViewData["Title"] = "Quản lí đơn đặt phòng";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&display=swap" rel="stylesheet">

<style>
       html, body {
       height: 100%;
       margin: 0;
   }
    body {
        background: linear-gradient(135deg, #F5EDE1, #feb47b);
        padding-top: 50px;
        font-family: Arial, sans-serif;
        color: #4E1F00;
    }

    h2 {
        font-family: 'Montserrat', sans-serif;
        font-weight: bold;
        color: #4E1F00;
        text-transform: uppercase;
    }

    .card-custom {
        background-color: #A27B5C;
        color: #FFF3C7;
        border-radius: 20px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    }

    .card-header-custom {
        background-color: #F9CB43;
        color: #4E1F00;
        text-align: center;
        border-radius: 20px 20px 0 0;
    }

    .table thead {
        background-color: #4E1F00;
        color: #FFF3C7;
    }

    .table td, .table th {
        vertical-align: middle;
        color: #4E1F00;
        background-color: #FFE699;
    }

    .btn-custom-success {
        background-color: #28a745;
        border: none;
        color: white;
        font-weight: bold;
    }

        .btn-custom-success:hover {
            background-color: green;
        }



    .btn-custom-secondary {
        background-color: #FFF3C7;
        color: #4E1F00;
        border: none;
        font-weight: bold;
    }

        .btn-custom-secondary:hover {
            background-color: #FFE699;
        }

    .badge {
        padding: 8px 12px;
        font-size: 0.9rem;
        font-weight: bold;
    }
</style>

<div class="container mt-4">
    <div class="card shadow-lg card-custom">
        <div class="card-header card-header-custom">
            <h2 class="mb-0">Quản lý đơn đặt phòng</h2>
        </div>
        <div class="card-body">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success">@TempData["Message"]</div>
            }

            <a asp-controller="Staff" asp-action="Index" class="btn btn-custom-secondary mb-3">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-bordered text-center">
                        <thead>
                            <tr>
                                <th>Homestay</th>
                                <th>Khách hàng</th>
                                <th>Ngày nhận phòng</th>
                                <th>Ngày trả phòng</th>
                                <th>Tổng giá</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var booking in Model)
                            {
                                <tr>
                                    <td>@booking.Homestay.Name</td>
                                    <td>@booking.User.UserName</td>
                                    <td>@booking.CheckInDate.ToString("dd/MM/yyyy")</td>
                                    <td>@booking.CheckOutDate.ToString("dd/MM/yyyy")</td>
                                    <td>@booking.TotalPrice.ToString("C")</td>
                                    <td>
                                        <span class="badge @(booking.Status == "Pending" ? "bg-warning text-dark" : (booking.Status == "Confirmed" ? "bg-success" : "bg-danger"))">
                                            @booking.Status
                                        </span>
                                    </td>
                                    <td>
                                        @if (booking.Status == "Pending")
                                        {
                                            <form asp-action="UpdateBookingStatus" method="post" class="d-inline">
                                                <input type="hidden" name="bookingId" value="@booking.Id" />
                                                <button type="submit" name="status" value="Confirmed" class="btn btn-custom-success btn-sm me-1">
                                                    <i class="bi bi-check-circle"></i> Xác nhận
                                                </button>
                                                <button type="submit" name="status" value="Rejected" class="btn btn-danger btn-sm">
                                                    <i class="bi bi-x-circle"></i> Từ chối
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-center text-muted">Không có đơn đặt phòng nào.</p>
            }
        </div>
    </div>
</div>
