@model List<DoAnCoSo_Nhom2.Models.Homestay>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&display=swap" rel="stylesheet">

<style>
    html, body {
        height: 100%;
        margin: 0;
    }
    body {
        background: linear-gradient(135deg, #F5EDE1, #feb47b);
        padding-top: 50px;
        font-family: Arial, sans-serif;
        color: #4E1F00;
    }

    .card {
        background-color: #A27B5C;
        color: #FFF3C7;
        border-radius: 20px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    }

    .card-header {
        background-color: #F9CB43;
        color: #4E1F00;
        font-family: 'Montserrat', sans-serif;
        text-transform: uppercase;
        font-size: 24px;
        border-top-left-radius: 20px;
        border-top-right-radius: 20px;
    }

    .btn-success {
        background: #FEBA17;
        border: none;
        color: #4E1F00;
        font-weight: bold;
    }

        .btn-success:hover {
            background: #F2E2B1;
        }

    .btn-secondary {
        background: #FFF3C7;
        color: #4E1F00;
        border: none;
        font-weight: bold;
    }

        .btn-secondary:hover {
            background: #FFE699;
        }

    .btn-warning {
        background-color: #f0ad4e;
        border: none;
    }

    .btn-danger {
        background-color: #d9534f;
        border: none;
    }

    .alert-info {
        background-color: #FFF3C7;
        color: #4E1F00;
        border: none;
    }

    .table th, .table td {
        background-color: #FFE699;
        vertical-align: middle;
        color: black;
    }

    .table thead {
        background-color: #4E1F00;
        color: #FFF3C7;
    }

    .badge.bg-success {
        background-color: #28a745;
    }

    .badge.bg-danger {
        background-color: #dc3545;
    }

    h2 {
        font-weight: bold;
        color: #FFF3C7 !important;
    }
</style>

<div class="container mt-4">
    <div class="card shadow-lg">
        <div class="card-header text-center">
            <h2 class="mb-0" style="color:#4E1F00 !important">Quản lý Homestay</h2>
        </div>
        <div class="card-body">
            <p class="alert alert-info">Thông báo mới: @ViewBag.Notification</p>

            <div class="mb-3 d-flex gap-2">
                <a asp-action="CreateHomestay" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Thêm Homestay mới
                </a>
                <a asp-action="ManageBookings" class="btn btn-secondary">
                    <i class="bi bi-calendar-check"></i> Quản lý đơn đặt phòng
                </a>
                <a asp-action="Notifications" class="btn btn-warning text-dark">
                    <i class="bi bi-bell"></i> Xem thông báo
                </a>
            </div>

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-bordered text-center">
                        <thead>
                            <tr>
                                <th>Tên</th>
                                <th>Địa chỉ</th>
                                <th>Giá mỗi đêm</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var homestay in Model)
                            {
                                <tr>
                                    <td>@homestay.Name</td>
                                    <td>@homestay.Address, @homestay.City</td>
                                    <td>@homestay.PricePerNight.ToString("C")</td>
                                    <td>
                                        <span class="badge @(homestay.Free ? "bg-success" : "bg-danger")">
                                            @(homestay.Free ? "Còn trống" : "Hết chỗ")
                                        </span>
                                    </td>
                                    <td>
                                        <a asp-action="EditHomestay" asp-route-id="@homestay.Id" class="btn btn-warning btn-sm">
                                            <i class="bi bi-pencil-square"></i> Sửa
                                        </a>
                                        <form asp-action="DeleteHomestay" asp-route-id="@homestay.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Bạn chắc chắn muốn xóa?')">
                                                <i class="bi bi-trash"></i> Xóa
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-center text-light">Bạn chưa có Homestay nào.</p>
            }
        </div>
    </div>
</div>
