@model DoAnCoSo_Nhom2.Models.Homestay

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&display=swap" rel="stylesheet">

<style>
    body {
        background: linear-gradient(135deg, #F5EDE1, #feb47b);
        padding-top: 50px;
        font-family: Arial, sans-serif;
        color: #4E1F00;
    }

    .form-container {
        background-color: #A27B5C;
        color: #F9CB43;
        border-radius: 20px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        padding: 30px;
        max-width: 900px;
        margin: 0 auto;
    }

        .form-container h2 {
            font-family: 'Montserrat', sans-serif;
            font-size: 28px;
            color: #FFF3C7;
            text-align: center;
            margin-bottom: 20px;
            text-transform: uppercase;
        }

    .form-label {
        font-weight: 600;
        color: #FFF3C7;
    }

    .form-control, .form-check-input {
        border-radius: 10px;
    }

    .btn-warning {
        background: #FEBA17;
        border: none;
        color: #4E1F00;
        font-weight: bold;
    }

        .btn-warning:hover {
            background: #F2E2B1;
        }

    .btn-secondary {
        background: #FFF3C7;
        color: #4E1F00;
        border: none;
        font-weight: bold;
    }

        .btn-secondary:hover {
            background: #FFE699;
        }

    .alert-validation {
        border-radius: 10px;
    }

    .form-check-label {
        color: #FFF3C7;
    }
</style>

<div class="form-container mt-4">
    <h2>Chỉnh sửa Homestay</h2>
    <form asp-action="EditHomestay" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger alert-validation"></div>
        }

        <div class="mb-3">
            <label class="form-label">Tên Homestay</label>
            <input asp-for="Name" class="form-control" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="3" required></textarea>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Địa chỉ</label>
                <input asp-for="Address" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Thành phố</label>
                <input asp-for="City" class="form-control" required />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Giá mỗi đêm</label>
            <input asp-for="PricePerNight" class="form-control" type="number" step="0.01" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Hình ảnh mới (thay thế hình cũ)</label>
            <input type="file" name="images" class="form-control" multiple />
        </div>

        <div class="mb-3">
            <label class="form-label">Tiện nghi</label>
            <div class="row">
                @foreach (var amenity in ViewBag.Amenities)
                {
                    <div class="col-md-4">
                        <div class="form-check">
                            <input type="checkbox" name="amenityIds" value="@amenity.Id" class="form-check-input"
                            @(Model.HomestayAmenities.Any(ha => ha.AmenityId == amenity.Id) ? "checked" : "") />
                            <label class="form-check-label">@amenity.Name</label>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="text-center">
            <button type="submit" class="btn btn-warning me-2">
                <i class="bi bi-save"></i> Cập nhật
            </button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </form>
</div>