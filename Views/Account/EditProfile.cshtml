@model DoAnCoSo_Nhom2.ViewModels.EditProfile

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chỉnh sửa thông tin cá nhân</title>

    <!-- Bootstrap + Bi Icons + Google Fonts -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #F5EDE1, #feb47b);
            padding-top: 50px;
            color: #4E1F00;
        }

        .form-container {
            background-color: #A27B5C;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
            max-width: 600px;
            margin: auto;
            color: #FFF3C7;
        }

        .form-label {
            font-weight: bold;
        }

        .form-control {
            border-radius: 10px;
            border: 2px solid #FFD699;
        }

        h3 {
            text-align: center;
            font-weight: bold;
            color: #FFF3C7;
            margin-bottom: 30px;
        }

        .btn-primary {
            background-color: #FEBA17;
            color: #4E1F00;
            border-radius: 10px;
        }

            .btn-primary:hover {
                background-color: #F2E2B1;
            }

        .btn-secondary {
            border-radius: 10px;
            background-color: #D6D6D6;
            color: #4E1F00;
        }

        .alert-success {
            border-radius: 10px;
            background-color: #FFF3C7;
            color: #4E1F00;
        }

        .text-danger {
            color: #FFEB3B !important;
        }
    </style>
</head>
<body>
    <div class="form-container">
        <h3>Chỉnh sửa thông tin cá nhân</h3>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success text-center">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            </div>
        }

        <form asp-action="EditProfile" method="post">
            <div class="mb-3">
                <label class="form-label">Họ và Tên</label>
                <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" required />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Địa chỉ</label>
                <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ" required />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Ngày sinh</label>
                <input asp-for="DateOfBirth" class="form-control" type="date" required />
                <span asp-validation-for="DateOfBirth" class="text-danger"></span>
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-save me-2"></i>Lưu thay đổi
                </button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary btn-lg ms-3">
                    <i class="bi bi-x-circle me-1"></i>Hủy
                </a>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>
