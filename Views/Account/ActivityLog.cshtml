@model List<DoAnCoSo_Nhom2.Models.UserActivityLog>
@{
    ViewData["Title"] = "Lịch sử hoạt động";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap + Bi Icons + Google Fonts -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            background: linear-gradient(135deg, #F5EDE1, #feb47b);
            padding-top: 50px;
            color: #4E1F00;
        }

        .activity-container {
            background-color: #A27B5C;
            color: #FFF3C7;
            border-radius: 20px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
            padding: 30px;
            max-width: 900px;
            margin: 0 auto;
        }

        h2 {
            font-size: 28px;
            font-weight: bold;
            color: #FFF3C7;
            text-align: center;
            margin-bottom: 30px;
            text-transform: uppercase;
        }

        .table th, .table thead {
            background-color: #4E1F00;
            color: #FFF3C7;
            vertical-align: middle;
        }

        .table td {
            background-color: #FFE699;
            color: #4E1F00;
            vertical-align: middle;
        }

        .btn-danger {
            background-color: #d9534f;
            border: none;
            border-radius: 10px;
            padding: 6px 14px;
            color: #fff;
            font-weight: bold;
        }

            .btn-danger:hover {
                background-color: #c82333;
            }

        .alert-info {
            font-size: 18px;
            font-weight: bold;
            background-color: #FFF3C7;
            color: #4E1F00;
            border: none;
            border-radius: 10px;
            padding: 15px;
        }
    </style>
</head>
<body>
    <div class="activity-container">
        <h2>Lịch sử hoạt động</h2>

        @if (Model.Count == 0)
        {
            <div class="alert alert-info text-center mt-3">
                Không có lịch sử hoạt động nào.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-bordered table-hover text-center">
                    <thead>
                        <tr>
                            <th>Thời gian</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td>@log.Timestamp.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@log.Action</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="text-center mt-4">
                <form asp-action="ClearActivityLog" method="post">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash3-fill"></i> Xóa lịch sử
                    </button>
                </form>
            </div>
            <div class="text-end mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
