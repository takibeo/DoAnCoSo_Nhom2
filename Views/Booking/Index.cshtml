@model List<DoAnCoSo_Nhom2.Models.Booking>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&display=swap" rel="stylesheet">

<style>
    html, body {
        height: 100%;
        margin: 0;
    }
    body {
        background: linear-gradient(135deg, #F5EDE1, #feb47b);
        padding-top: 50px;
    }

    h2 {
        font-size: 28px;
        font-weight: bold;
        color: #FFF3C7 !important;
        text-transform: uppercase;
        text-align: center;
        margin-bottom: 30px;
    }

    .table th {
        background-color: #4E1F00;
        color: #FFF3C7;
        vertical-align: middle;
    }

    #myBookingTable td {
        background-color: #FFE699 !important;
        color: #4E1F00;
        vertical-align: middle;
    }

    .badge {
        font-size: 0.9em;
        padding: 5px 10px;
        border-radius: 10px;
    }

    .btn-primary,
    .btn-danger {
        border-radius: 8px;
        font-weight: bold;
    }

    .btn-primary {
        background-color: #FFF3C7;
        color: #4E1F00;
        border: none;
    }

    .btn-danger {
        background-color: #A94442;
        border: none;
    }

    .btn-primary:hover {
        background-color: #F2E2B1;
    }

    .alert-info {
        font-size: 18px;
        font-weight: bold;
        background-color: #FFF3C7;
        color: #4E1F00;
        border: none;
        border-radius: 10px;
    }

    .alert-success,
    .alert-danger {
        font-size: 16px;
        font-weight: bold;
        border-radius: 10px;
    }

    .dataTables_length label,
    .dataTables_filter label,
    .dataTables_info,
    .dataTables_paginate {
        color: #4E1F00 !important;
        font-size: 16px;
    }

        .dataTables_filter input,
        .dataTables_paginate a {
            font-size: 16px !important;
            color: #4E1F00 !important;
            background-color: white !important;
            border: 1px solid #ccc !important;
            border-radius: 6px;
            padding: 4px 8px;
            margin: 2px;
        }

        .dataTables_paginate .paginate_button {
            padding: 6px 12px;
            margin: 2px;
        }

            .dataTables_paginate .paginate_button:hover {
                background-color: #f1f1f1 !important;
                color: #4E1F00 !important;
                border: 1px solid #4E1F00 !important;
            }

    .dataTables_wrapper .dataTables_paginate .paginate_button.current {
        background-color: white !important;
        color: #FFF3C7 !important;
        border: 1px solid #4E1F00 !important;
    }
</style>

<h2 style="color:#4E1F00 !important ">Homestay của bạn</h2>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">Bạn chưa đặt Homestay nào.</div>
}
else
{
    <div class="table-responsive">
        <table id="myBookingTable" class="table table-bordered table-hover text-center">
            <thead>
                <tr>
                    <th>Hình ảnh</th>
                    <th>Tên Homestay</th>
                    <th>Địa điểm</th>
                    <th>Ngày nhận</th>
                    <th>Ngày trả</th>
                    <th>Số khách</th>
                    <th>Tổng tiền</th>
                    <th>Cọc trước 30%</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model)
                {
                    var deposit = booking.TotalPrice * 0.3m;
                    <tr>
                        <td>
                            <img src="@booking.Homestay.Images.FirstOrDefault()"
                                 alt="Homestay" class="rounded shadow-sm"
                                 width="100" height="80"
                                 onerror="this.src='/images/default.jpg';" />
                        </td>
                        <td>@booking.Homestay.Name</td>
                        <td>@booking.Homestay.City</td>
                        <td>@booking.CheckInDate.ToString("dd/MM/yyyy")</td>
                        <td>@booking.CheckOutDate.ToString("dd/MM/yyyy")</td>
                        <td>@booking.NumberOfGuests</td>
                        <td>@booking.TotalPrice.ToString("N0") VND</td>
                        <td>@deposit.ToString("N0") VND</td>
                        <td>
                            <span class="badge
                                @(booking.Status == "Confirmed" ? "bg-success" :
                                  booking.Status == "Cancelled" ? "bg-danger" : "bg-warning")">
                                @booking.Status
                            </span>
                        </td>
                        <td>
                            @if (booking.Status == "Pending")
                            {
                                <div class="d-flex justify-content-center gap-2">
                                    <form asp-controller="Booking" asp-action="PaymentCallbackVnpay" method="get">
                                        <input type="hidden" name="bookingId" value="@booking.Id" />
                                        <button type="submit" class="btn btn-primary btn-sm">Thanh toán</button>
                                    </form>
                                    <a asp-controller="Booking" asp-action="Cancel" asp-route-id="@booking.Id"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('Bạn có chắc chắn muốn hủy đặt phòng này?');">
                                        Hủy đặt phòng
                                    </a>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">Không thể hủy</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success mt-3">@TempData["Message"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-3">@TempData["Error"]</div>
}

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#myBookingTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json'
                }
            });
        });
    </script>
}
