@model DoAnCoSo_Nhom2.ViewModels.BookingCreateViewModel

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

<style>
    html, body {
        height: 100%;
        margin: 0;
    }

    body {
        border-bottom: 3px solid black;
        background: linear-gradient(135deg, #F5EDE1, #feb47b);
        padding-top: 50px;
        color: #4E1F00;
    }

    h2 {
        font-weight: bold;
        color: orangered !important;
        text-align: center;
        margin-bottom: 30px;
        text-transform: uppercase;
    }

    .card {
        background-color: #FFF3C7;
        border-radius: 20px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        max-width: 700px;
        margin: 0 auto;
        padding: 30px;
        border: none;
    }

    label {
        font-weight: bold;
    }

    .form-control {
        border-radius: 10px;
        border: 1px solid #A27B5C;
    }

    .btn-primary {
        background-color: #A27B5C;
        border: none;
        font-weight: bold;
        border-radius: 10px;
    }

        .btn-primary:hover {
            background-color: #8a6244;
        }

    .text-danger {
        font-size: 0.9em;
    }

    .alert-danger {
        background-color: #ffdddd;
        color: #b20000;
        border-radius: 10px;
    }
</style>

<h2>Thêm vào giỏ hàng</h2>

<div class="card">
    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="needs-validation" novalidate>
        @* Chỉ hiện thông báo nếu có lỗi *@
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
        {
            <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>
        }

        <input type="hidden" asp-for="HomestayId" value="@ViewBag.HomeStayId" />

        <div class="mb-3">
            <label for="CheckInDate" class="form-label">Ngày nhận phòng</label>
            <input type="date" asp-for="CheckInDate" class="form-control" required />
            <span asp-validation-for="CheckInDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label for="CheckOutDate" class="form-label">Ngày trả phòng</label>
            <input type="date" asp-for="CheckOutDate" class="form-control" required />
            <span asp-validation-for="CheckOutDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label for="NumberOfGuests" class="form-label">Số khách</label>
            <input type="number" asp-for="NumberOfGuests" class="form-control" min="1" required />
            <span asp-validation-for="NumberOfGuests" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Thêm vào giỏ hàng</button>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
