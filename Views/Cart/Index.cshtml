@model List<DoAnCoSo_Nhom2.Models.Cart>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

<style>
    html, body {
        height: 100%;
        margin: 0;
    }

    body {
        background: linear-gradient(135deg, #F5EDE1, #feb47b);
        padding-top: 50px;
        color: #4E1F00;
    }

    .cart-container {
        background-color: #A27B5C;
        color: #FFF3C7;
        border-radius: 20px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        padding: 30px;
        max-width: 1000px;
        margin: 0 auto;
    }

    h2 {
        font-size: 28px;
        font-weight: bold;
        color: #FFF3C7;
        text-align: center;
        margin-bottom: 30px;
        text-transform: uppercase;
    }

    .table th, .table thead {
        background-color: #4E1F00;
        color: #FFF3C7;
        vertical-align: middle;
    }

    .table td {
        background-color: #FFE699;
        color: #4E1F00;
        vertical-align: middle;
    }

    .btn-danger {
        background-color: #d9534f;
        border: none;
        border-radius: 10px;
        padding: 5px 12px;
        color: #fff;
    }

    .btn-success {
        background-color: #FEBA17;
        border: none;
        border-radius: 10px;
        font-weight: bold;
        color: #4E1F00;
    }

        .btn-success:hover {
            background-color: #F2E2B1;
        }

    .total-deposit {
        font-size: 18px;
        font-weight: bold;
        color: #FFF3C7;
    }

        .total-deposit span {
            color: #FFEB3B;
        }

    .alert-info {
        font-size: 18px;
        font-weight: bold;
        background-color: #FFF3C7;
        color: #4E1F00;
        border: none;
        border-radius: 10px;
    }
</style>

<div class="cart-container">
    <h2>Giỏ hàng của bạn</h2>

    @if (Model.Any())
    {
        decimal totalDeposit = 0;

        <div class="table-responsive">
            <table class="table table-hover table-bordered text-center">
                <thead>
                    <tr>
                        <th>Tên Homestay</th>
                        <th>Ngày nhận</th>
                        <th>Ngày trả</th>
                        <th>Số khách</th>
                        <th>Tổng giá (VND)</th>
                        <th>Cọc trước (30%)</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var deposit = item.TotalPrice * 0.3M;
                        totalDeposit += deposit;
                        <tr>
                            <td>@item.Homestay.Name</td>
                            <td>@item.CheckInDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.CheckOutDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.NumberOfGuests</td>
                            <td>@item.TotalPrice.ToString("N0")</td>
                            <td class="text-success fw-bold">@deposit.ToString("N0")</td>
                            <td>
                                <a asp-action="Remove" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4">
            <div class="total-deposit">
                Tổng cọc trước (30%): <span>@totalDeposit.ToString("N0")</span> VND
            </div>
            <a asp-action="Checkout" class="btn btn-success btn-lg">
                <i class="bi bi-credit-card"></i> Thanh toán
            </a>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center mt-3">
            Giỏ hàng của bạn đang trống.
        </div>
    }
</div>
